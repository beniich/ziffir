{
  "title": "Zaphir - Sécurité & Conformité",
  "tags": ["zaphir", "security", "soc2"],
  "panels": [
    {
      "title": "🚨 Événements de sécurité",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(security_events_total[5m])) by (type, severity)",
          "legendFormat": "{{severity}} - {{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 80 },
          "unit": "ops"
        }
      }
    },
    {
      "title": "🔒 Verrouillages de compte (anti-brute-force)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum(increase(zaphir_auth_lockouts_total[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ] }
        }
      }
    },
    {
      "title": "⛔ IP bloquées",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 6 },
      "targets": [
        { "expr": "sum(zaphir_blocked_ips)" }
      ]
    },
    {
      "title": "🌍 Top pays des requêtes",
      "type": "table",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 6 },
      "targets": [
        {
          "expr": "topk(10, sum by (geo_country) (rate(http_requests_total[10m])))",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "🛡️ Audit chain integrity",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "zaphir_audit_chain_valid"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "❌ COMPROMISED", "color": "red" }, "1": { "text": "✓ VALID", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ] }
        }
      }
    },
    {
      "title": "🔍 Top actions sensibles",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "expr": "topk(10, sum by (action) (rate(zaphir_audit_logs_created_total[1h])))",
          "format": "table",
          "instant": true
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "refresh": "30s",
  "uid": "zaphir-security"
}
