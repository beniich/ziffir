# Production Environment Variables for Zaphir Frontend (Vercel)
# Copy these exact variable names into your Vercel dashboard
# Settings > Environment Variables > Add

# ── API Backend (cPanel) ──────────────────────────────────────
VITE_API_URL=https://api.zaphir.ricecloud.net/api

# ── Stripe Public Key (REPLACE with your pk_live_ key) ───────
VITE_STRIPE_PUBLIC_KEY=pk_live_REPLACE_WITH_YOUR_LIVE_KEY

# ── Firebase ──────────────────────────────────────────────────
VITE_FIREBASE_PROJECT_ID=zaphir-auth
