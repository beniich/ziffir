generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════
// ENUMS
// ════════════════════════════════════════════════════════════

enum UserRole {
  VISITOR
  CLIENT
  HOTEL
  SUPER_ADMIN
}

enum OrderStatus {
  PREPARATION
  QUALITY_CHECK
  OUT_FOR_DELIVERY
  DELIVERED
}

enum RoomStatus {
  VACANT
  OCCUPIED
  CLEANING
  MAINTENANCE
}

// ════════════════════════════════════════════════════════════
// HOTEL (Multi-tenant anchor)
// ════════════════════════════════════════════════════════════

model Hotel {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  city      String?
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  users       User[]
  orders      RoomOrder[]
  rooms       Room[]
  staff       StaffMember[]
  audits      Audit[]
  pricing     PricingRule[]
  suites      SuiteControl[]
  vaultDocs   VaultDocument[]
  courses     Course[]
  subscription Subscription?

  @@map("hotels")
}

// ════════════════════════════════════════════════════════════
// USER
// ════════════════════════════════════════════════════════════

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  username        String     @unique
  passwordHash    String     @map("password_hash")
  role            UserRole   @default(CLIENT)
  
  // Multi-tenant : NULL pour visitor, client, super_admin
  hotelId         String?    @map("hotel_id")
  hotel           Hotel?     @relation(fields: [hotelId], references: [id])
  
  // Pour le rôle CLIENT : sa chambre actuelle
  currentRoomId   String?    @map("current_room_id")
  currentRoom     Room?      @relation("GuestRoom", fields: [currentRoomId], references: [id])
  
  // Sécurité
  failedAttempts  Int        @default(0) @map("failed_attempts")
  lockedUntil     DateTime?  @map("locked_until") @db.Timestamptz()
  refreshToken    String?    @map("refresh_token")
  lastLogin       DateTime?  @map("last_login") @db.Timestamptz()
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime   @updatedAt @db.Timestamptz()

  // Relations
  guestOrders     RoomOrder[] @relation("GuestOrders")

  @@index([email])
  @@index([hotelId])
  @@index([role])
  @@map("users")
}

// ════════════════════════════════════════════════════════════
// ROOM
// ════════════════════════════════════════════════════════════

model Room {
  id          String     @id @default(cuid())
  hotelId     String     @map("hotel_id")
  hotel       Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  number      String
  floor       Int
  type        String     // 'standard' | 'suite' | 'penthouse' | 'villa'
  status      RoomStatus @default(VACANT)
  isActive    Boolean    @default(true) @map("is_active")

  orders      RoomOrder[]
  controls    SuiteControl?
  guests      User[]     @relation("GuestRoom")

  @@unique([hotelId, number])
  @@index([hotelId, status])
  @@map("rooms")
}

// ════════════════════════════════════════════════════════════
// ROOM ORDER
// ════════════════════════════════════════════════════════════

model RoomOrder {
  id                String      @id @default(cuid())
  orderRef          String      @unique @map("order_ref")
  hotelId           String      @map("hotel_id")
  hotel             Hotel       @relation(fields: [hotelId], references: [id])
  
  // Client
  guestId           String?     @map("guest_id")
  guest             User?       @relation("GuestOrders", fields: [guestId], references: [id])
  guestName         String      @map("guest_name")
  guestVIP          Boolean     @default(false) @map("guest_vip")
  
  roomId            String?     @map("room_id")
  room              Room?       @relation(fields: [roomId], references: [id])
  roomNumber        String      @map("room_number")
  
  status            OrderStatus @default(PREPARATION)
  priority          String      @default("normal")
  notes             String?     @db.Text
  
  subtotal          Decimal     @db.Decimal(10, 2)
  vat               Decimal     @db.Decimal(10, 2)
  serviceCharge     Decimal     @db.Decimal(10, 2) @map("service_charge")
  total             Decimal     @db.Decimal(10, 2)
  
  estimatedDelivery DateTime?   @map("estimated_delivery") @db.Timestamptz()
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime    @updatedAt @db.Timestamptz()

  items             OrderItem[]

  @@index([hotelId, status])
  @@index([hotelId, createdAt])
  @@index([guestId])
  @@map("room_orders")
}

model OrderItem {
  id          String    @id @default(cuid())
  orderId     String    @map("order_id")
  order       RoomOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courseCode  String    @map("course_code")
  course      Course    @relation(fields: [courseCode], references: [code])
  name        String
  quantity    Int       @default(1)
  price       Decimal   @db.Decimal(10, 2)

  @@index([orderId])
  @@map("order_items")
}

// ════════════════════════════════════════════════════════════
// COURSE
// ════════════════════════════════════════════════════════════

model Course {
  code        String      @id
  hotelId     String?     @map("hotel_id")
  hotel       Hotel?      @relation(fields: [hotelId], references: [id])
  
  name        String
  nameFr      String?     @map("name_fr")
  category    String
  price       Decimal     @db.Decimal(10, 2)
  prepTime    Int         @default(15) @map("prep_time")
  available   Boolean     @default(true)
  allergens   String      @default("")
  vectorKey   String?     @map("vector_key")

  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime    @updatedAt @db.Timestamptz()

  orderItems  OrderItem[]

  @@index([hotelId])
  @@map("courses")
}

// ════════════════════════════════════════════════════════════
// STAFF
// ════════════════════════════════════════════════════════════

model StaffMember {
  id              String    @id @default(cuid())
  staffRef        String    @unique @map("staff_ref")
  hotelId         String    @map("hotel_id")
  hotel           Hotel     @relation(fields: [hotelId], references: [id])
  
  name            String
  role            String
  department      String
  clearanceLevel  Int       @default(1) @map("clearance_level")
  active          Boolean   @default(true)
  lastAccess      DateTime? @map("last_access") @db.Timestamptz()

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @db.Timestamptz()

  @@index([hotelId])
  @@map("staff")
}

// ════════════════════════════════════════════════════════════
// VAULT DOCUMENT
// ════════════════════════════════════════════════════════════

model VaultDocument {
  id          String    @id @default(cuid())
  hotelId     String    @map("hotel_id")
  hotel       Hotel     @relation(fields: [hotelId], references: [id])
  
  docRef      String    @unique @map("doc_ref")
  name        String
  category    String
  owner       String
  room        String
  fingerprint Boolean   @default(true)
  depositDate DateTime  @default(now()) @map("deposit_date") @db.Timestamptz()
  withdrawnAt DateTime? @map("withdrawn_at") @db.Timestamptz()

  @@index([hotelId])
  @@index([owner])
  @@map("vault_documents")
}

// ════════════════════════════════════════════════════════════
// SUITE CONTROL
// ════════════════════════════════════════════════════════════

model SuiteControl {
  id            String   @id @default(cuid())
  hotelId       String   @map("hotel_id")
  hotel         Hotel    @relation(fields: [hotelId], references: [id])
  roomId        String   @unique @map("room_id")
  room          Room     @relation(fields: [roomId], references: [id])
  
  controlRef    String   @unique @map("control_ref")
  suite         String
  lights        Boolean  @default(false)
  climate       Int      @default(20)
  curtains      String   @default("closed")
  music         Boolean  @default(false)
  musicVolume   Int      @default(0) @map("music_volume")
  doNotDisturb  Boolean  @default(false) @map("do_not_disturb")

  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([hotelId])
  @@map("suite_controls")
}

// ════════════════════════════════════════════════════════════
// PRICING RULE
// ════════════════════════════════════════════════════════════

model PricingRule {
  id                 String   @id @default(cuid())
  hotelId            String   @map("hotel_id")
  hotel              Hotel    @relation(fields: [hotelId], references: [id])
  
  ruleRef            String   @unique @map("rule_ref")
  suite              String
  basePrice          Decimal  @db.Decimal(10, 2) @map("base_price")
  channelMultipliers String   @default("{}") @map("channel_multipliers")
  lastSync           DateTime @default(now()) @map("last_sync") @db.Timestamptz()
  status             String   @default("synced")

  @@index([hotelId])
  @@map("pricing_rules")
}

// ════════════════════════════════════════════════════════════
// AUDIT LOG
// ════════════════════════════════════════════════════════════

model Audit {
  id           String   @id @default(cuid())
  logId        String   @unique @map("log_id")
  hotelId      String?  @map("hotel_id")
  hotel        Hotel?   @relation(fields: [hotelId], references: [id])
  
  timestamp    DateTime @default(now()) @db.Timestamptz()
  user         String
  role         String
  action       String
  reason       String   @db.Text
  previousHash String   @map("previous_hash")
  hash         String   @unique
  status       String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([hotelId, timestamp(sort: Desc)])
  @@index([action])
  @@index([user])
  @@map("audits")
}

// ════════════════════════════════════════════════════════════
// LEDGER COURSE (global)
// ════════════════════════════════════════════════════════════

model LedgerCourse {
  code           String   @id
  name           String
  category       String
  credits        Float
  grade          String
  completedDate  String   @map("completed_date")
  blockchainHash String?  @unique @map("blockchain_hash")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @db.Timestamptz()

  @@map("ledger_courses")
}

// ════════════════════════════════════════════════════════════
// PUSH TOKEN (Mobile)
// ════════════════════════════════════════════════════════════

model PushToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  hotelId   String?
  platform  String   // 'ios' | 'android'
  deviceId  String?
  isActive  Boolean  @default(true)
  lastUsed  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([hotelId])
  @@map("push_tokens")
}

// ════════════════════════════════════════════════════════════
// BILLING — Subscriptions, Invoices, Usage
// ════════════════════════════════════════════════════════════

enum Plan {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  UNCOLLECTIBLE
  VOID
}

model Subscription {
  id                   String    @id @default(cuid())
  hotelId              String    @unique
  hotel                Hotel     @relation(fields: [hotelId], references: [id])

  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?

  plan                 Plan      @default(TRIAL)
  status               SubStatus @default(TRIALING)

  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAt             DateTime?
  canceledAt           DateTime?
  trialEndsAt          DateTime?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  invoices             Invoice[]
  usage                UsageRecord[]

  @@map("subscriptions")
}

model Invoice {
  id              String        @id @default(cuid())
  subscriptionId  String
  subscription    Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  stripeInvoiceId String        @unique
  number          String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("eur")
  status          InvoiceStatus @default(DRAFT)

  paidAt          DateTime?
  dueAt           DateTime?
  pdfUrl          String?

  lineItems       Json

  createdAt       DateTime      @default(now())

  @@index([subscriptionId])
  @@index([status])
  @@map("invoices")
}

model UsageRecord {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  metric          String       // 'api_calls' | 'rooms' | 'staff' | 'storage_gb'
  value           Int
  period          DateTime

  createdAt       DateTime     @default(now())

  @@index([subscriptionId, metric, period])
  @@map("usage_records")
}
