{
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_API_URL": "https://api-dev.zaphir.com/api" }
    },
    "preview": {
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_API_URL": "https://api-staging.zaphir.com/api" }
    },
    "production": {
      "env": { "EXPO_PUBLIC_API_URL": "https://api.zaphir.com/api" }
    }
  },
  "submit": {
    "production": {
      "ios": { "ascAppId": "1234567890" },
      "android": { "packageName": "com.zaphir.app" }
    }
  }
}
